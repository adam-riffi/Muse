# Backend runtime configuration (parsed and validated in src/config.ts)
NODE_ENV=development
PORT=3001
HOST=127.0.0.1
LOG_LEVEL=info

# Agent CLI that drives discovery/propositions: 'codex' (default) or 'copilot'
AGENT_CLI=codex
# Optional binary overrides (defaults: codex / copilot on PATH)
# CODEX_BIN=codex
# COPILOT_BIN=copilot

# Optional image source (alternative to the agent CLI for references)
IMAGE_SOURCE=openverse
# UNSPLASH_ACCESS_KEY=

# Vision-language model for synthesis: 'copilot' (uses the local Copilot CLI, no key),
# 'anthropic', 'openai', or 'none'
VLM_PROVIDER=copilot
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# VLM_MODEL=
